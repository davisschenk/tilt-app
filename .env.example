# PostgreSQL connection string (used by Rust server and sea-orm-cli)
# In a git worktree, set DB_NAME/DB_PORT to a unique value to avoid conflicts.
DATABASE_URL=postgres://tilt:password@localhost:5432/tilt

# Rocket secret key for private cookies (generate with: openssl rand -base64 32)
ROCKET_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32

# Rocket server port (set a unique value per worktree, e.g. 8001, 8002)
ROCKET_PORT=8000

# Logging level (trace, debug, info, warn, error)
RUST_LOG=info

# --- Docker / Worktree isolation ---
# Each git worktree should use unique values for DB_NAME, DB_PORT, and PORT
# to avoid container and port conflicts when running multiple worktrees.
#
# Database name inside Postgres (unique per worktree, e.g. tilt_feat1)
DB_NAME=tilt
# Postgres user
DB_USER=tilt
# Database password
DB_PASSWORD=password
# Host port Postgres listens on (unique per worktree, e.g. 5433, 5434)
DB_PORT=5432
# Host port the API server is exposed on (unique per worktree, e.g. 8001, 8002)
PORT=8000

# --- OAuth2 / Authentik ---
# ⚠️  SECURITY WARNING: If AUTHENTIK_ISSUER_URL is left empty, the server starts
# with authentication DISABLED — all API endpoints are accessible without login.
# This is intentional for local development only.
# NEVER deploy to a network-accessible host without setting these values.
#
# OIDC issuer URL (e.g. https://auth.example.com/application/o/tiltbrew/)
AUTHENTIK_ISSUER_URL=

# OAuth2 client credentials from Authentik provider
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=

# Redirect URL registered in Authentik (must match exactly)
AUTHENTIK_REDIRECT_URL=http://localhost:8000/api/v1/auth/callback

# --- CORS / Frontend ---
# Comma-separated allowed origins for CORS (leave empty to allow all in dev)
FRONTEND_URL=http://localhost:5173

# URL the server redirects to after successful login
# (defaults to / which serves the SPA)
# FRONTEND_URL_POST_LOGIN=http://localhost:5173

# --- File Uploads ---
# Directory where photo attachments are stored (relative or absolute path)
UPLOAD_DIR=./uploads

# --- OTA Firmware Updates ---
# Firmware version string served to ESP32 clients (semver recommended)
OTA_FIRMWARE_VERSION=0.0.0

# Full URL to the firmware .bin file (leave empty to disable OTA endpoint)
OTA_FIRMWARE_URL=
