# ═══════════════════════════════════════════════════════════════════════════
# Tilt App env config — used by docker compose, the Rust server, the seeder,
# and the just recipes. In a worktree, `just wt-add` produces a copy of this
# file with slug-derived DB_NAME and (after `just up`) allocated ports.
# ═══════════════════════════════════════════════════════════════════════════

# --- Stack identity (worktree isolation) ---
# Compose project name. "main" for the primary repo, "wt_<branch_slug>" for worktrees.
COMPOSE_PROJECT_NAME=main

# Per-worktree cargo build directory. Resolved against the worktree root.
# Override to share a cache (at the cost of build-lock contention).
CARGO_TARGET_DIR=./target

# --- Database ---
DATABASE_URL=postgres://tilt:password@localhost:5432/tilt
DB_NAME=tilt
DB_USER=tilt
DB_PASSWORD=password
# Host port Postgres is published on. Empty = `just up` allocates a free port.
DB_PORT=5432

# --- Server ---
# Host port the server is published on (and Rocket binds in host mode).
# Empty = `just up` allocates a free port.
PORT=8000
ROCKET_PORT=8000

# Rocket secret key for private cookies (generate: openssl rand -base64 32)
ROCKET_SECRET_KEY=CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32

# Logging level (trace, debug, info, warn, error)
RUST_LOG=info

# --- Auth ---
# Master switch for authentication. Two values:
#   disabled = no auth, server injects a fixed dev user (LOCAL DEV / TEST INSTANCES ONLY)
#   oidc     = enforce OpenID Connect (Authentik, Auth0, Keycloak, etc.)
#
# ⚠️  SECURITY: deploying with AUTH_MODE=disabled to a network-accessible host
# means anyone on that network has full admin access to your data.
AUTH_MODE=disabled

# --- OIDC (only used when AUTH_MODE=oidc) ---
AUTHENTIK_ISSUER_URL=
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
AUTHENTIK_REDIRECT_URL=http://localhost:8000/api/v1/auth/callback

# --- CORS / Frontend ---
# Comma-separated allowed origins for CORS (leave empty to allow all in dev)
FRONTEND_URL=http://localhost:5173

# URL the server redirects to after successful login (defaults to / which serves the SPA)
# FRONTEND_URL_POST_LOGIN=http://localhost:5173

# Vite dev server's API target (only read by `npm run dev`).
# Worktrees should set this to http://localhost:${PORT} after `just up`.
# VITE_API_URL=http://localhost:8000/api/v1

# --- File Uploads ---
UPLOAD_DIR=./uploads

# --- OTA Firmware Updates ---
OTA_FIRMWARE_VERSION=0.0.0
OTA_FIRMWARE_URL=

# --- Marimo Notebooks ---
# Directory where per-brew marimo notebook .py files are stored.
NOTEBOOK_DIR=./notebooks
# Base port for marimo edit servers (one process per brew, ports allocated starting here).
MARIMO_PORT_BASE=2718
# Host/IP that marimo binds to (use 0.0.0.0 to expose on all interfaces).
MARIMO_HOST=127.0.0.1
# Hostname used to construct the URL returned to the browser (set to your server's hostname/IP if remote).
MARIMO_EXTERNAL_HOST=localhost
